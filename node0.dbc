VERSION "DeviceStatus v1"

NS_ :
    NS_DESC_
    CM_
    BA_DEF_
    BA_
    VAL_
    CAT_DEF_
    CAT_
    FILTER
    BA_DEF_DEF_
    EV_DATA_
    ENVVAR_DATA_
    SGTYPE_
    SGTYPE_VAL_
    BA_DEF_SGTYPE_
    BA_SGTYPE_
    SIG_TYPE_REF_
    VAL_TABLE_
    SIG_GROUP_
    SIG_VALTYPE_
    SIGTYPE_VALTYPE_
    BO_TX_BU_
    BA_DEF_REL_
    BA_REL_
    BA_DEF_DEF_REL_
    BU_SG_REL_
    BU_EV_REL_
    BU_BO_REL_
    SG_MUL_VAL_

BS_:

BU_: TEENSY HOST

BO_ 256 DEVICE_STATUS_NODE0: 8 TEENSY
 SG_ schema_version : 0|8@1+  (1,0) [0|255] "" HOST
 SG_ device_state   : 8|8@1+  (1,0) [0|2]   "" HOST
 SG_ unused_0       : 16|8@1+ (1,0) [0|255] "" HOST
 SG_ unused_1       : 24|8@1+ (1,0) [0|255] "" HOST
 SG_ unused_2       : 32|8@1+ (1,0) [0|255] "" HOST
 SG_ unused_3       : 40|8@1+ (1,0) [0|255] "" HOST
 SG_ unused_4       : 48|8@1+ (1,0) [0|255] "" HOST
 SG_ unused_5       : 56|8@1+ (1,0) [0|255] "" HOST

VAL_ 256 device_state 0 "NODE_INIT" 1 "NODE_ACTIVE" 2 "NODE_FAULT";

CM_ BO_ 256 "Device status message. Actual firmware sends this at CAN ID 0x100 + nodeData.id.";
CM_ SG_ 256 schema_version "Schema version byte from nodeData.schema_version.";
CM_ SG_ 256 device_state "Raw node state enum from nodeData.state.";
CM_ SG_ 256 status_flags "Currently always 0 in firmware.";
CM_ SG_ 256 uptime_s "Currently always 0 in firmware.";
CM_ SG_ 256 heartbeat_counter "Currently always 0 in firmware.";
CM_ SG_ 256 reserved "Currently always 0 in firmware.";

BA_DEF_ BO_ "GenMsgCycleTime" INT 0 65535;
BA_ "GenMsgCycleTime" BO_ 256 1000;